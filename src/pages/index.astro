---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";

const categories = [
  {
    href: "/categories/kitchen/",
    title: "Kitchen",
    description: "Bench space, pantry choices, dinner prep, cleaning and tools that earn their place.",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and a tidy benchtop.",
  },
  {
    href: "/categories/laundry/",
    title: "Laundry",
    description: "Washing flow, drying space, hampers, cleaning supplies and the awkward corners of a small laundry.",
    image: "/images/laundry.webp",
    imageAlt: "A practical laundry room with warm finishes and tidy storage.",
  },
  {
    href: "/categories/bedroom/",
    title: "Bedroom",
    description: "Comfort, bedding, wardrobes, bedside habits and making a smaller bedroom work.",
    image: "/images/bedroom.webp",
    imageAlt: "A calm bedroom with soft bedding, warm light and practical storage.",
  },
  {
    href: "/categories/bathroom/",
    title: "Bathroom",
    description: "Vanity drawers, towel space, shower routines and cleaning access for busy bathrooms.",
    image: "/images/bathroom.webp",
    imageAlt: "A tidy bathroom with warm finishes, practical storage and soft natural light.",
  },
  {
    href: "/categories/pets/",
    title: "Pets",
    description: "Feeding, bedding, cleaning, travel and the way pets actually live in the home.",
    image: "/images/pet.webp",
    imageAlt: "A relaxed living room with warm timber, soft textiles and a pet-friendly setup.",
  },
  {
    href: "/categories/nursery-kids/",
    title: "Nursery & Kids",
    description: "Baby essentials, sleep, bath time, outings, growth and what can wait.",
    image: "/images/Nursery-kids.webp",
    imageAlt: "A tidy nursery room with timber furniture, soft lighting and practical baby storage.",
  },
  {
    href: "/categories/living-spaces/",
    title: "Living Spaces",
    description: "Seating, media, lighting, family clutter and shared rooms that are easier to put back together.",
    image: "/images/living-room.webp",
    imageAlt: "A warm living room with tidy storage, soft seating and natural light.",
  },
  {
    href: "/categories/home-office/",
    title: "Home Office",
    description: "Desk fit, lighting, calls, cables and workdays that fit the room.",
    image: "/images/home-office.webp",
    imageAlt: "A compact home office setup with a tidy desk, warm light and practical storage.",
  },
  {
    href: "/categories/garage-storage/",
    title: "Garage Storage Ideas",
    description: "Plan tools, tubs, shelves and wall storage while keeping the car, doors and walking routes clear.",
    image: "/images/garage.webp",
    imageAlt: "An organised garage with wall storage, shelves and clear floor space.",
  },
  {
    href: "/categories/outdoor-garden/",
    title: "Outdoor & Garden",
    description: "Weather, shade, plants, entertaining and keeping outdoor areas workable between uses.",
    image: "/images/outdoor-garden.webp",
    imageAlt: "A warm Australian patio garden with outdoor seating, greenery and practical storage.",
  },
];

const featuredGuides = [
  {
    href: "/guides/pantry-storage-ideas-australian-kitchens/",
    title: "Pantry Storage Ideas for Australian Kitchens",
    description: "Fix deep shelves, hidden food and packet clutter without buying a full set of matching containers.",
    meta: "Kitchen",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and tidy pantry-style storage.",
  },
  {
    href: "/guides/everyday-kitchen-essentials-australian-homes/",
    title: "Everyday Kitchen Essentials for Australian Homes",
    description: "Cookware, utensils, food storage and cleaning basics that earn a spot in daily use.",
    meta: "Kitchen",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and practical everyday kitchen storage.",
  },
  {
    href: "/guides/bedroom-storage-ideas-small-australian-rooms/",
    title: "Bedroom Storage Ideas for Small Australian Rooms",
    description: "Wardrobe, under-bed and bedside ideas for rooms that need to stay calm.",
    meta: "Bedroom",
    image: "/images/bedroom.webp",
    imageAlt: "A calm small bedroom with soft bedding, warm light and practical storage.",
  },
  {
    href: "/guides/bathroom-essentials-australian-homes/",
    title: "Bathroom Essentials for Australian Homes",
    description: "Towels, shower basics, vanity items and cleaning gear for everyday bathrooms.",
    meta: "Bathroom",
    image: "/images/bathroom.webp",
    imageAlt: "A tidy bathroom with warm finishes, soft light and practical everyday storage.",
  },
  {
    href: "/guides/washing-machine-and-dryer-space-what-to-measure-before-buying-storage/",
    title: "Laundry Dimensions Australia",
    description: "Check washer, dryer, cavity, door and lid dimensions before planning cabinetry or storage.",
    meta: "Laundry",
    image: "/images/laundry.webp",
    imageAlt: "A practical laundry room with warm finishes, baskets and tidy everyday storage.",
  },
  {
    href: "/guides/pet-essentials-for-australian-homes/",
    title: "Pet Essentials for Australian Homes",
    description: "Feeding, bedding, cleaning, grooming and travel basics for pet-friendly homes.",
    meta: "Pets",
    image: "/images/pet.webp",
    imageAlt: "A relaxed pet-friendly living room with warm timber, soft textiles and tidy storage.",
  },
  {
    href: "/guides/nursery-essentials-for-australian-homes/",
    title: "Nursery Essentials for Australian Homes",
    description: "Sleep, feeding, changing, bathing and nursery choices that suit your room.",
    meta: "Nursery & Kids",
    image: "/images/Nursery-kids.webp",
    imageAlt: "A tidy nursery room with timber furniture, soft lighting and practical baby storage.",
  },
];
---

<BaseLayout
  title="Australian Home Collective"
  seoTitle="Australian Home Collective | Practical Home Guides"
  description="Practical Australian home guides for storage, room planning and smarter buying decisions—measure first, compare what matters and avoid costly mismatches."
>
  <section class="hero image-hero">
    <img
      class="hero-bg"
      src="/images/home-lifestyle-hero.jpg"
      alt="A warm Australian home interior with timber furniture, greenery, kitchen and living spaces"
      width="1800"
      height="1100"
      loading="eager"
      draggable="false"
    />
    <div class="container hero-content">
      <div class="hero-copy">
        <p class="eyebrow">For Australian homes</p>
        <h1>Practical home guides for better buying decisions</h1>
        <p class="lead">
          We look at how home products fit into real rooms and routines: what is worth
          measuring, what may be harder to clean than expected and what you can probably
          leave on the shelf.
        </p>
        <div class="hero-actions">
          <a class="button" href="/guides/">Browse Guides</a>
          <a class="button secondary" href="/categories/">Browse Categories</a>
        </div>
      </div>
    </div>
  </section>

  <div class="section soft">
    <div class="container grid three">
      <article class="card feature-card">
        <p class="eyebrow">Australian households</p>
        <h2>Advice that starts with the home</h2>
        <p>
          Guides for kitchens, laundries, bathrooms, bedrooms, pets, nurseries and the rooms
          everyone ends up sharing.
        </p>
      </article>
      <article class="card feature-card">
        <p class="eyebrow">Before spending</p>
        <h2>Work out what matters first</h2>
        <p>
          Room fit, cleaning effort and the way something will be used usually matter more
          than how it looks in a product photo.
        </p>
      </article>
      <article class="card feature-card">
        <p class="eyebrow">A considered approach</p>
        <h2>Buy only when it helps</h2>
        <p>
          Sometimes a small change, a better arrangement or something you already own can
          solve the problem. When a purchase would genuinely help, we explain what to look for.
        </p>
      </article>
    </div>
  </div>

  <section class="section">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Browse by category</p>
        <h2>Explore by area of the home</h2>
      </div>
      <p>
        Pick the room or household job that is bothering you now.
      </p>
    </div>
    <div class="container grid three">
      {categories.map((category) => (
        <GuideCard
          href={category.href}
          title={category.title}
          description={category.description}
          meta="Category"
          image={category.image}
          imageAlt={category.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section soft">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Guide library</p>
        <h2>A good place to begin</h2>
      </div>
      <p>
        A selection from around the home, including kitchens, laundry, pets, bedrooms,
        bathrooms and family routines.
      </p>
    </div>
    <div class="container grid three">
      {featuredGuides.map((guide) => (
        <GuideCard
          href={guide.href}
          title={guide.title}
          description={guide.description}
          meta={guide.meta}
          image={guide.image}
          imageAlt={guide.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Our approach</p>
        <h2>How we choose what to cover</h2>
        <p>
          A topic earns its place when it helps with a real household decision. We look at
          room size, use, cleaning, comfort and whether buying something is necessary at all.
        </p>
      </div>
      <div class="card">
        <p class="eyebrow">Learn more</p>
        <h2>Clear about what earns a place</h2>
        <p>
          Read how we choose topics, handle product claims and decide when a recommendation
          would genuinely help.
        </p>
        <div class="button-row">
          <a class="button" href="/how-we-select-products/">How We Select</a>
          <a class="button secondary" href="/our-approach/">Our Approach</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
