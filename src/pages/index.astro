---
import BaseLayout from "../layouts/BaseLayout.astro";
import GuideCard from "../components/GuideCard.astro";

const categories = [
  {
    href: "/categories/kitchen/",
    title: "Kitchen",
    description: "Storage, pantry planning, everyday tools and practical kitchen routines.",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and a tidy benchtop.",
  },
  {
    href: "/categories/laundry/",
    title: "Laundry",
    description: "Drying, sorting, cleaning, storage and practical laundry setup ideas.",
    image: "/images/laundry.webp",
    imageAlt: "A practical laundry room with warm finishes and tidy storage.",
  },
  {
    href: "/categories/bedroom/",
    title: "Bedroom",
    description: "Storage, bedding, wardrobe organisation and small-room ideas.",
    image: "/images/bedroom.webp",
    imageAlt: "A calm bedroom with soft bedding, warm light and practical storage.",
  },
  {
    href: "/categories/bathroom/",
    title: "Bathroom",
    description: "Storage, towels, cleaning and everyday setup for busy bathrooms.",
    image: "/images/bathroom.webp",
    imageAlt: "A tidy bathroom with warm finishes, practical storage and soft natural light.",
  },
  {
    href: "/categories/pets/",
    title: "Pets",
    description: "Pet bedding, feeding, cleaning, travel, storage and indoor comfort.",
    image: "/images/pet.webp",
    imageAlt: "A relaxed living room with warm timber, soft textiles and a pet-friendly setup.",
  },
  {
    href: "/categories/nursery-kids/",
    title: "Nursery & Kids",
    description: "Nursery setup, baby essentials, kids' storage and family home basics.",
    image: "/images/Nursery-kids.webp",
    imageAlt: "A tidy nursery room with timber furniture, soft lighting and practical baby storage.",
  },
  {
    href: "/categories/living-spaces/",
    title: "Living Spaces",
    description: "Lounge room comfort, storage, lighting and everyday living room organisation.",
    image: "/images/living-room.webp",
    imageAlt: "A warm living room with tidy storage, soft seating and natural light.",
  },
  {
    href: "/categories/home-office/",
    title: "Home Office",
    description: "Desk setup, storage, lighting, cable control and work-from-home basics.",
    image: "/images/home-office.webp",
    imageAlt: "A compact home office setup with a tidy desk, warm light and practical storage.",
  },
  {
    href: "/categories/garage-storage/",
    title: "Garage Storage",
    description: "Shelving, tubs, tools and storage that helps keep the floor clear.",
    image: "/images/garage.webp",
    imageAlt: "An organised garage with wall storage, shelves and clear floor space.",
  },
  {
    href: "/categories/outdoor-garden/",
    title: "Outdoor & Garden",
    description: "Outdoor storage, patio basics, garden tools and weather-aware setup ideas.",
    image: "/images/outdoor-garden.webp",
    imageAlt: "A warm Australian patio garden with outdoor seating, greenery and practical storage.",
  },
];

const featuredGuides = [
  {
    href: "/guides/pantry-storage-ideas-australian-kitchens/",
    title: "Pantry Storage Ideas for Australian Kitchens",
    description: "Practical pantry organisation ideas for containers, baskets, labels and shelf planning.",
    meta: "Kitchen",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and tidy pantry-style storage.",
  },
  {
    href: "/guides/everyday-kitchen-essentials-australian-homes/",
    title: "Everyday Kitchen Essentials for Australian Homes",
    description: "Practical cookware, food storage, utensil and cleaning basics for daily kitchen use.",
    meta: "Kitchen",
    image: "/images/kitchen.webp",
    imageAlt: "A warm kitchen with timber cabinetry, green accents and practical everyday kitchen storage.",
  },
  {
    href: "/guides/bedroom-storage-ideas-small-australian-rooms/",
    title: "Bedroom Storage Ideas for Small Australian Rooms",
    description: "Practical wardrobe, under-bed, bedside and everyday clutter storage ideas.",
    meta: "Bedroom",
    image: "/images/bedroom.webp",
    imageAlt: "A calm small bedroom with soft bedding, warm light and practical storage.",
  },
  {
    href: "/guides/bathroom-essentials-australian-homes/",
    title: "Bathroom Essentials for Australian Homes",
    description: "Practical towel, shower, vanity, toilet and cleaning basics for everyday bathrooms.",
    meta: "Bathroom",
    image: "/images/bathroom.webp",
    imageAlt: "A tidy bathroom with warm finishes, soft light and practical everyday storage.",
  },
  {
    href: "/guides/laundry-essentials-australian-homes/",
    title: "Laundry Essentials for Australian Homes",
    description: "Practical hamper, basket, drying, cleaning and small laundry setup ideas.",
    meta: "Laundry",
    image: "/images/laundry.webp",
    imageAlt: "A practical laundry room with warm finishes, baskets and tidy everyday storage.",
  },
  {
    href: "/guides/pet-essentials-for-australian-homes/",
    title: "Pet Essentials for Australian Homes",
    description: "Feeding, bedding, cleaning, grooming, travel and storage basics for pet-friendly homes.",
    meta: "Pets",
    image: "/images/pet.webp",
    imageAlt: "A relaxed pet-friendly living room with warm timber, soft textiles and tidy storage.",
  },
  {
    href: "/guides/nursery-essentials-for-australian-homes/",
    title: "Nursery Essentials for Australian Homes",
    description: "A practical nursery setup guide covering sleep, feeding, changing, storage and comfort.",
    meta: "Nursery & Kids",
    image: "/images/Nursery-kids.webp",
    imageAlt: "A tidy nursery room with timber furniture, soft lighting and practical baby storage.",
  },
];
---

<BaseLayout
  title="Australian Home Collective"
  description="Practical buying guides for Australian homes, covering kitchens, laundries, bedrooms, bathrooms, pets, nurseries, living spaces, home offices, garages and outdoor areas."
>
  <section class="hero image-hero">
    <img
      class="hero-bg"
      src="/images/home-lifestyle-hero.jpg"
      alt="A warm Australian home interior with timber furniture, greenery, kitchen and living spaces"
      width="1800"
      height="1100"
      loading="eager"
      draggable="false"
    />
    <div class="container hero-content">
      <div class="hero-copy">
        <p class="eyebrow">Product guides for Australian homes</p>
        <h1>Helpful guidance before you buy</h1>
        <p class="lead">
          Australian Home Collective helps you think through your space, storage needs and
          everyday routines before choosing what to bring into your home.
        </p>
        <div class="hero-actions">
          <a class="button" href="/guides/">Browse Guides</a>
          <a class="button secondary" href="/categories/">Browse Categories</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section soft">
    <div class="container grid three">
      <article class="card">
        <p class="eyebrow">Everyday homes</p>
        <h2>Made for Australian households</h2>
        <p>
          Room-by-room guides for kitchens, laundries, bathrooms, bedrooms, pets, nurseries
          and shared family spaces.
        </p>
      </article>
      <article class="card">
        <p class="eyebrow">Plan first</p>
        <h2>Practical help for real rooms</h2>
        <p>
          Our guides focus on measurements, layout, storage problems and everyday use, so you
          can make better choices before spending money.
        </p>
      </article>
      <article class="card">
        <p class="eyebrow">Choose with care</p>
        <h2>Helpful guidance before you buy</h2>
        <p>
          We help you compare product types, storage options and everyday trade-offs before
          deciding what suits your home.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Browse by category</p>
        <h2>Explore by area of the home</h2>
      </div>
      <p>
        Start with the room, routine or household setup you are working on now.
      </p>
    </div>
    <div class="container grid three">
      {categories.map((category) => (
        <GuideCard
          href={category.href}
          title={category.title}
          description={category.description}
          meta="Category"
          image={category.image}
          imageAlt={category.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section soft">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Guide library</p>
        <h2>Start with these guides</h2>
      </div>
      <p>
        A balanced set of practical guides across storage, family essentials, pets, laundry,
        kitchen and everyday home setup.
      </p>
    </div>
    <div class="container grid three">
      {featuredGuides.map((guide) => (
        <GuideCard
          href={guide.href}
          title={guide.title}
          description={guide.description}
          meta={guide.meta}
          image={guide.image}
          imageAlt={guide.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Our approach</p>
        <h2>How we choose what to include</h2>
        <p>
          We look at how a product type fits into everyday Australian homes: the space it
          needs, how it is used, how easy it is to clean and when it may be worth skipping.
        </p>
      </div>
      <div class="card">
        <p class="eyebrow">Learn more</p>
        <h2>Clear, practical and selective</h2>
        <p>
          Read more about how we choose topics, compare product types and keep guides useful
          for readers.
        </p>
        <div class="button-row">
          <a class="button" href="/how-we-select-products/">How We Select</a>
          <a class="button secondary" href="/our-approach/">Our Approach</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
