    links: [
      { href: "/guides/lower-waste-laundry-essentials/", title: "Lower-Waste Laundry Essentials" },
      { href: "/guides/laundry-organisation-ideas-that-save-space/", title: "Laundry Organisation Ideas That Actually Save Space" },
      { title: "Drying Rack Options", status: "Planned guide" },
