<BaseLayout
  title="Guides"
  seoTitle="Australian Home Guides: Storage, Rooms and Better Buys"
  description="Practical Australian home guides for storage, room planning and everyday routines—find what to measure, compare and avoid before you buy."
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide library</p>
      <h1>Practical Australian home guides by room and routine</h1>
      <p class="lead">
        Browse by room or routine. The guides cover fit, cleaning, comfort, storage and the
        purchases that may be better left for later.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>A few places to begin</h2>
      </div>
      <p>
        A selection from around the home, from kitchen cupboards and laundry days to pets
        and shared family rooms.
      </p>
    </div>
    <div class="container grid three">
      {featuredGuides.map((guide) => (
        <GuideCard
          href={guide.href}
          title={guide.title}
          description={guide.description}
          meta={guide.category}
          image={guide.image}
          imageAlt={guide.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section soft">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Browse by category</p>
        <h2>Browse all guide sections</h2>
      </div>
      <p>
        Find a guide by room, routine or household problem, then open the category page for
        the rest of that section.
      </p>
    </div>
    <div class="container guide-library-grid">
      {guideGroups.map((group) => (
        <section class="guide-library-group" aria-labelledby={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
          <h3 id={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
            {group.title}
          </h3>
          <p>{group.description}</p>
          <ul>
            {group.links.map((item) => (
              <li>
                <a href={item.href}>{item.title}</a>
              </li>
            ))}
          </ul>
          {group.categoryHref && (
            <p>
              <a href={group.categoryHref}>View {group.title} category</a>
            </p>
          )}
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
