---

<BaseLayout
  title="Guides"
  description="Practical guides for everyday living at home, covering organisation, family essentials, pets, laundry, kitchen, storage and more."
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide library</p>
      <h1>Guides</h1>
      <p class="lead">
        Practical guides for everyday living at home, covering organisation, family
        essentials, pets, laundry, kitchen, storage and more.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Featured Guides</h2>
      </div>
      <p>
        A balanced selection of developed guides across family, pets, laundry, kitchen and
        home organisation.
      </p>
    </div>
    <div class="container grid three">
      {featuredGuides.map((guide) => (
        <GuideCard
          href={guide.href}
          title={guide.title}
          description={guide.description}
          meta="Guide"
          image={guide.image}
          imageAlt={guide.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section soft">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Browse by topic</p>
        <h2>Guide Sections</h2>
      </div>
      <p>
        Find current guides and planned topics by the room, routine or household decision you
        are working through.
      </p>
    </div>
    <div class="container guide-library-grid">
      {guideGroups.map((group) => (
        <section class="guide-library-group" aria-labelledby={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
          <h3 id={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
            {group.title}
          </h3>
          <p>{group.description}</p>
          <ul>
            {group.links.map((item) => (
              <li>
                {item.href ? <a href={item.href}>{item.title}</a> : <span>{item.title}</span>}
                {item.status && <span class="guide-status">{item.status}</span>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
