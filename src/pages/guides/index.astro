---

<BaseLayout
  title="Guides"
  description="Practical Australian home guides covering kitchen, laundry, bedroom, bathroom, pets, nursery, living spaces, home office, garage storage and outdoor setup."
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide library</p>
      <h1>Practical Australian home guides</h1>
      <p class="lead">
        Browse practical guides for kitchens, laundries, bedrooms, bathrooms, pets, nurseries,
        living spaces, home offices, garage storage and outdoor areas. Each guide helps you
        think through fit, layout, storage, cleaning and daily use before choosing what to
        bring home.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Start with these guides</h2>
      </div>
      <p>
        A short selection of useful guides across the main areas of the home.
      </p>
    </div>
    <div class="container grid three">
      {featuredGuides.map((guide) => (
        <GuideCard
          href={guide.href}
          title={guide.title}
          description={guide.description}
          meta={guide.category}
          image={guide.image}
          imageAlt={guide.imageAlt}
        />
      ))}
    </div>
  </section>

  <section class="section soft">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Browse by category</p>
        <h2>Guide sections</h2>
      </div>
      <p>
        Find published guides by room, routine or household setup. Each section links to its
        full category hub.
      </p>
    </div>
    <div class="container guide-library-grid">
      {guideGroups.map((group) => (
        <section class="guide-library-group" aria-labelledby={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
          <h3 id={`${group.title.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}-heading`}>
            {group.title}
          </h3>
          <p>{group.description}</p>
          <ul>
            {group.links.map((item) => (
              <li>
                <a href={item.href}>{item.title}</a>
              </li>
            ))}
          </ul>
          {group.categoryHref && (
            <p>
              <a href={group.categoryHref}>View {group.title} category</a>
            </p>
          )}
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
