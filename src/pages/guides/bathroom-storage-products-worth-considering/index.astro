---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const target = "/guides/bathroom-storage-what-to-measure-and-check-before-you-buy/";
---

<BaseLayout
  title="Bathroom Storage Ideas has moved"
  description="This bathroom guide has moved to the main bathroom storage planning guide."
  canonicalPath={target}
  refreshPath={target}
  robots="noindex,follow"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide moved</p>
      <h1>This bathroom guide has moved.</h1>
      <p class="lead">
        The product ideas are now part of the main bathroom storage guide, with measurement,
        moisture and cleaning checks in one place.
      </p>
      <div class="button-row">
        <a class="button" href={target}>Open the bathroom storage guide</a>
        <a class="button secondary" href="/categories/bathroom/">Browse bathroom guides</a>
      </div>
    </div>
  </header>
</BaseLayout>
