---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const target = "/guides/laundry-storage-what-to-measure-and-check-before-you-buy/";
---

<BaseLayout
  title="Laundry Organisation Ideas has moved"
  description="This laundry guide has moved to the main laundry storage planning guide."
  canonicalPath={target}
  refreshPath={target}
  robots="noindex,follow"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide moved</p>
      <h1>This laundry guide has moved.</h1>
      <p class="lead">
        The organisation ideas are now part of the main laundry storage guide, with room planning,
        drying space and daily routines in one place.
      </p>
      <div class="button-row">
        <a class="button" href={target}>Open the laundry storage guide</a>
        <a class="button secondary" href="/categories/laundry/">Browse laundry guides</a>
      </div>
    </div>
  </header>
</BaseLayout>
