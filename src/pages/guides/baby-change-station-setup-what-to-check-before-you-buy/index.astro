---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const target = "/guides/nappy-change-station-checklist/";
---

<BaseLayout
  title="Baby Change Station Setup has moved"
  description="This baby change-area guide has moved to the nappy change station checklist."
  canonicalPath={target}
  refreshPath={target}
  robots="noindex,follow"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide moved</p>
      <h1>This baby change-area guide has moved.</h1>
      <p class="lead">
        The room-planning, surface, supply and safety checks are now included in the nappy change
        station checklist.
      </p>
      <div class="button-row">
        <a class="button" href={target}>Open the nappy change station checklist</a>
        <a class="button secondary" href="/categories/nursery-kids/">Browse nursery guides</a>
      </div>
    </div>
  </header>
</BaseLayout>
