    <li><a href="https://ncc.abcb.gov.au/editions/ncc-2022/adopted/housing-provisions/10-health-and-amenity/part-106-ventilation" target="_blank" rel="noopener noreferrer">NCC 2022 Housing Provisions: ventilation</a></li>
    <li><a href="https://ncc.abcb.gov.au/editions/ncc-2022/adopted/housing-provisions/10-health-and-amenity/part-102-wet-area-waterproofing" target="_blank" rel="noopener noreferrer">NCC 2022 Housing Provisions: wet-area waterproofing</a></li>
    <li><a href="https://www.haier.com.au/laundry/washing-machines/10kg-500-series-front-loader-washing-machine-hwf10nw1-62392.html" target="_blank" rel="noopener noreferrer">Haier Australia 10 kg front loader specifications</a></li>
    <li><a href="https://www.electrolux.com.au/laundry/washing-machines/ewf1043r7wcs/" target="_blank" rel="noopener noreferrer">Electrolux Australia 10 kg front loader specifications</a></li>
    <li><a href="https://www.lg.com/au/partners/laundry/washing-machines/wv10-1412b/" target="_blank" rel="noopener noreferrer">LG Australia 12 kg front loader specifications</a></li>
    <li><a href="https://www.samsung.com/au/washers-and-dryers/washing-machines/ww9400b-smart-front-loading-bubblewash-ai-wash-bespoke-design-12kg-black-ww12bb94adgbsa/" target="_blank" rel="noopener noreferrer">Samsung Australia 12 kg front loader specifications</a></li>
    <li><a href="https://www.fisherpaykel.com/au/laundry/washing-machines/front-load/12kg-series-9-contemporary-front-loader-washer-flexidose-wh1260tg5-92315.html" target="_blank" rel="noopener noreferrer">Fisher &amp; Paykel Australia 12 kg front loader specifications</a></li>
  </ul>

