const faqs = [
  {
    question: "Are dishwashers a standard size in Australia?",
    answer: "Most full size models are made for a nominal 600 mm wide space, but actual product width, height and installation requirements vary. Measure the finished opening at several points and use the exact model's installation guide.",
  },
