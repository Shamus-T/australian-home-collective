---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const target = "/guides/pet-essentials-for-australian-homes/";
---

<BaseLayout
  title="Pet-Friendly Home Products has moved"
  description="This pet-friendly home guide has moved to the complete pet essentials guide."
  canonicalPath={target}
  refreshPath={target}
  robots="noindex,follow"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Guide moved</p>
      <h1>This pet-friendly home guide has moved.</h1>
      <p class="lead">
        The feeding, resting, cleaning, floor-protection and daily-zone advice is now included in
        the complete pet essentials guide.
      </p>
      <div class="button-row">
        <a class="button" href={target}>Open the pet essentials guide</a>
        <a class="button secondary" href="/categories/pets/">Browse pet guides</a>
      </div>
    </div>
  </header>
</BaseLayout>
