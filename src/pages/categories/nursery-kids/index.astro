---
import CategoryHubLayout from "../../../layouts/CategoryHubLayout.astro";
import GuideCard from "../../../components/GuideCard.astro";
import ProductCard from "../../../components/ProductCard.astro";
import FAQBlock from "../../../components/FAQBlock.astro";

const faqs = [
  {
    question: "What nursery items should I buy first?",
    answer: "Prioritise a safe sleep space, nappies, wipes, feeding basics, simple clothing, changing supplies, baby linen and a practical laundry plan. Styling and decorative extras can wait.",
  },
  {
    question: "How do I organise a small nursery?",
    answer: "Keep daily-use items close to the routine that needs them. Store nappies near the change area, clothing in simple drawer zones and bulk supplies or next-size clothes elsewhere if space is tight.",
  },
  {
    question: "What kids' storage is most useful?",
    answer: "Baskets, low shelves, drawer dividers and labelled tubs are often more useful than large decorative storage because they are easier to reset as toys, books and clothing change.",
  },
];
---

<CategoryHubLayout
  title="Nursery & Kids"
  seoTitle="Nursery and Kids' Room Guides for Australian Homes"
  description="Australian nursery and kids guides for newborn essentials, sleep, bath time, outings, changing routines, growth and what can wait."
  intro="Guides for Australian families planning baby routines now and adaptable play, clothing and school-item storage as children grow."
  image="/images/Nursery-kids.webp"
  imageAlt="A tidy nursery room with timber furniture, soft lighting and practical baby storage"
  faqs={faqs}
>
  <section class="section" data-category-section="guide-collection">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Nursery and kids guides</h2>
      </div>
      <p>
        Sleep, changing, washing and outings shape the first months. Play, books, clothes and
        school gear need flexible space as the child grows.
      </p>
    </div>
    <div class="container grid three">
      <GuideCard
        href="/guides/nursery-essentials-for-australian-homes/"
        title="Nursery Essentials for Australian Homes"
        description="Sleep, feeding, changing, bathing and nursery choices that suit your room."
        meta="Guide"
      />
      <GuideCard
        href="/guides/newborn-essentials/"
        title="Newborn Essentials for New Parents"
        description="The things that tend to earn their place in the first few months, plus what can wait."
        meta="Guide"
      />
      <GuideCard
        href="/guides/bassinet-vs-cot/"
        title="Bassinet vs Cot: Which One Makes Sense First?"
        description="Compare space, budget, safety checks, mattress fit and age suitability."
        meta="Guide"
      />
      <GuideCard
        href="/guides/baby-monitors-australia/"
        title="Baby Monitors for Australian Homes"
        description="Compare audio and video monitors, with or without Wi-Fi, including range, privacy and placement."
        meta="Guide"
      />
      <GuideCard
        href="/guides/nursery-storage-small-rooms/"
        title="Nursery Storage for Small Rooms"
        description="Ways to use a compact, rented or shared room without filling every spare corner."
        meta="Guide"
      />
      <GuideCard
        href="/guides/baby-bath-time-essentials/"
        title="Baby Bath Time: What You Need Close By"
        description="Prepare towels, wash items, drying space and clean clothes before water is involved."
        meta="Guide"
      />
      <GuideCard
        href="/guides/nappy-change-station-checklist/"
        title="Nappy Change Station Checklist"
        description="A changing area for nappies, wipes, creams and cleaning up without keeping supplies all over the room."
        meta="Guide"
      />
      <GuideCard
        href="/guides/baby-outing-essentials-what-to-pack-before-leaving-the-house/"
        title="What to Pack When You Leave the House With a Baby"
        description="Pack nappies, wipes, spare clothes, feeding items and weather gear without taking the whole nursery with you."
        meta="Guide"
      />
      <GuideCard
        href="/guides/kids-play-and-toy-storage-what-to-plan-before-buying/"
        title="A Kids’ Play Zone That Is Easy to Reset"
        description="Plan toy, book, craft and school-item storage around current activities and room to play."
        meta="Guide"
      />
    </div>
  </section>

  <section class="section soft" data-category-section="planning-focus">
    <div class="container">
      <p class="eyebrow">Areas to compare</p>
      <h2>What tends to matter first</h2>
      <div class="grid three">
        <ProductCard
          label="Newborn essentials"
          title="Start with daily care"
          description="Sort out safe sleep, feeding, nappies, washing, clothing and transport before spending on extras."
        />
        <ProductCard
          label="Baby sleep"
          title="Fit and safety matter"
          description="Check mattress fit, ventilation, age suitability, room space and current Australian safety guidance before choosing a sleep setup."
        />
        <ProductCard
          label="Nursery furniture"
          title="Make the furniture fit the room"
          description="Look at stability, clearances, cleaning and whether the furniture leaves enough room to move."
        />
        <ProductCard
          label="Nursery storage"
          title="Keep the things you use close"
          description="Nappies, clothes, wraps and towels need to be within reach without crowding the change or sleep area."
        />
        <ProductCard
          label="Baby monitors"
          title="Match features to your home"
          description="Consider camera placement, signal, audio quality, privacy settings, charging and whether your home layout really needs one."
        />
        <ProductCard
          label="Bath time"
          title="Prepare before water is involved"
          description="Have towels, clean clothes and wash items ready, and follow manufacturer instructions for supports or accessories."
        />
        <ProductCard
          label="Nappy changing"
          title="Set up the change area"
          description="A stable surface, supplies within reach and somewhere for dirty items usually matter more than dedicated furniture."
        />
        <ProductCard
          label="Prams and outings"
          title="Think beyond the first walk"
          description="Plan what needs to be packed, where it will sit in the car or pram, and how easy the setup is to reset after each outing."
        />
        <ProductCard
          label="Kids play and learning"
          title="Leave room for growth"
          description="Choose storage and play items that still work as interests, skills and room layouts change."
        />
      </div>
    </div>
  </section>

  <section class="section" data-category-section="questions-and-mistakes">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Before deciding</p>
        <h2>Checks that deserve attention</h2>
        <ul class="feature-list">
          <li>Age, weight and size suitability for the child using the item.</li>
          <li>Current Australian safety guidance, recalls and safety notices where relevant.</li>
          <li>Manufacturer instructions for assembly, use, care and ongoing checks.</li>
          <li>Room measurements, storage, ventilation, traffic flow and rental limitations.</li>
          <li>Washability, age suitability, storage flexibility and how long the item is likely to be useful.</li>
        </ul>
      </div>
      <div>
        <p class="eyebrow">Common mistakes</p>
        <h2>Where families can waste money</h2>
        <ul class="feature-list">
          <li>Choosing furniture before measuring doors, walls and safe clearances.</li>
          <li>Buying too many newborn-only items before knowing your actual routine.</li>
          <li>Assuming a popular item suits every room or every baby.</li>
          <li>Keeping packaging or instructions separate from safety-sensitive items.</li>
          <li>Ignoring washable surfaces for clothes, linen, mats and storage.</li>
          <li>Adding decorative extras before the core care routine is sorted.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section soft" data-category-section="nearby-categories">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Related areas</p>
        <h2>Explore nearby categories</h2>
      </div>
      <p>
        Baby routines spill into bedrooms, bathrooms and the laundry, so those rooms may
        need attention too.
      </p>
    </div>
    <div class="container grid two">
      <GuideCard
        href="/categories/bedroom/"
        title="Bedroom"
        description="Bedding, wardrobes, light and making a smaller room work."
        meta="Category"
      />
      <GuideCard
        href="/categories/bathroom/"
        title="Bathroom"
        description="Bath routines, towel drying, cleaning and bathrooms shared by the family."
        meta="Category"
      />
    </div>
  </section>

  <section class="section" data-category-section="common-questions">
    <div class="narrow">
      <FAQBlock items={faqs} />
    </div>
  </section>
</CategoryHubLayout>
