---
import BaseLayout from "../../layouts/BaseLayout.astro";

const target = "/about/";
---

<BaseLayout
  title="Our Approach has moved"
  description="The Australian Home Collective approach is now explained on the About page."
  canonicalPath={target}
  refreshPath={target}
  robots="noindex,follow"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Page moved</p>
      <h1>Our approach has moved.</h1>
      <p class="lead">
        Our planning-first approach is now part of the About page.
      </p>
      <div class="button-row">
        <a class="button" href={target}>Read about Australian Home Collective</a>
        <a class="button secondary" href="/editorial-standards/">Read our editorial standards</a>
      </div>
    </div>
  </header>
</BaseLayout>
