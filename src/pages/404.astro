---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found"
  description="The page could not be found. Return to Australian Home Collective for practical Australian home and lifestyle guides."
  canonicalPath="/404.html"
>
  <header class="page-intro">
    <div class="narrow">
      <p class="eyebrow">Page not found</p>
      <h1>This guide is not available.</h1>
      <p class="lead">
        The page may have moved, or the address may not be quite right. You can return to the
        home page or start with the Nursery & Kids guide hub.
      </p>
      <div class="button-row">
        <a class="button" href="/">Go to homepage</a>
        <a class="button secondary" href="/categories/nursery-kids/">Open Nursery & Kids</a>
      </div>
    </div>
  </header>
</BaseLayout>
