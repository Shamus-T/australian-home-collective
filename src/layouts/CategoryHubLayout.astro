---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getCategorySocialImage } from "../data/socialImages";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  intro: string;
  image?: string;
  imageAlt?: string;
  imagePosition?: string;
  socialImage?: string;
  socialImageAlt?: string;
}

const {
  title,
  seoTitle,
  description,
  intro,
  image = "/images/living-room.webp",
  imageAlt = "A warm, tidy Australian home interior",
  imagePosition = "center",
  socialImage,
  socialImageAlt,
} = Astro.props;

const categorySocialImage = getCategorySocialImage(title);
const resolvedSocialImage = socialImage ?? categorySocialImage.src;
const resolvedSocialImageAlt = socialImageAlt
  ?? (socialImage ? `${title} guides - Australian Home Collective` : categorySocialImage.alt);
const siteUrl = "https://australianhomecollective.com.au";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const breadcrumbItems = [
  { name: "Home", href: "/" },
  { name: "Categories", href: "/categories/" },
  { name: title },
];
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: new URL(item.href ?? Astro.url.pathname, siteUrl).toString(),
  })),
};
---

<BaseLayout title={title} seoTitle={seoTitle} description={description} image={resolvedSocialImage} imageAlt={resolvedSocialImageAlt} structuredData={[breadcrumbSchema]}>
  <header class="category-header image-header">
    <img
      class="header-image"
      src={image}
      alt={imageAlt}
      width="1600"
      height="720"
      loading="eager"
      draggable="false"
      style={`object-position: ${imagePosition};`}
    />
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />
      <p class="eyebrow">Category Guide</p>
      <h1>{title}</h1>
      <p class="lead">{intro}</p>
    </div>
  </header>
  <slot />
</BaseLayout>
