---
import BaseLayout from "./BaseLayout.astro";
import { getCategorySocialImage } from "../data/socialImages";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  intro: string;
  image?: string;
  imageAlt?: string;
  imagePosition?: string;
  socialImage?: string;
  socialImageAlt?: string;
}

const {
  title,
  seoTitle,
  description,
  intro,
  image = "/images/living-room.webp",
  imageAlt = "A warm, tidy Australian home interior",
  imagePosition = "center",
  socialImage,
  socialImageAlt,
} = Astro.props;

const categorySocialImage = getCategorySocialImage(title);
const resolvedSocialImage = socialImage ?? categorySocialImage.src;
const resolvedSocialImageAlt = socialImageAlt
  ?? (socialImage ? `${title} guides - Australian Home Collective` : categorySocialImage.alt);
---

<BaseLayout title={title} seoTitle={seoTitle} description={description} image={resolvedSocialImage} imageAlt={resolvedSocialImageAlt}>
  <header class="category-header image-header">
    <img
      class="header-image"
      src={image}
      alt={imageAlt}
      width="1600"
      height="720"
      loading="eager"
      draggable="false"
      style={`object-position: ${imagePosition};`}
    />
    <div class="container">
      <p class="eyebrow">Category Guide</p>
      <h1>{title}</h1>
      <p class="lead">{intro}</p>
    </div>
  </header>
  <slot />
</BaseLayout>
