---
import BaseLayout from "./BaseLayout.astro";
import AffiliateDisclosureBlock from "../components/AffiliateDisclosureBlock.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import FAQBlock from "../components/FAQBlock.astro";
import { getCategoryPath } from "../data/categories";
import { getCategorySocialImage } from "../data/socialImages";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  category: string;
  date: string;
  datePublished?: string;
  dateModified?: string;
  readingTime: string;
  showAffiliateDisclosure?: boolean;
  showDisclosure?: boolean;
  image?: string;
  imageAlt?: string;
  socialImage?: string;
  socialImageAlt?: string;
  imagePosition?: string;
  faqs?: Array<{
    question: string;
    answer: string;
  }>;
}

const {
  title,
  seoTitle,
  description,
  category,
  date,
  datePublished,
  dateModified,
  readingTime,
  showAffiliateDisclosure,
  showDisclosure,
  image,
  imageAlt = "",
  socialImage,
  socialImageAlt,
  imagePosition = "center",
  faqs = [],
} = Astro.props;

const shouldShowDisclosure = showAffiliateDisclosure ?? showDisclosure ?? false;
const categorySocialImage = getCategorySocialImage(category);
const resolvedSocialImage = socialImage ?? categorySocialImage.src;
const resolvedSocialImageAlt = socialImageAlt
  ?? (socialImage ? `${title} - Australian Home Collective` : categorySocialImage.alt);
const siteUrl = "https://australianhomecollective.com.au";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const organizationId = `${siteUrl}/#organization`;
const categoryPath = getCategoryPath(category);
const breadcrumbItems = categoryPath
  ? [
      { name: "Home", href: "/" },
      { name: "Categories", href: "/categories/" },
      { name: category, href: categoryPath },
      { name: title },
    ]
  : [
      { name: "Home", href: "/" },
      { name: "Guides", href: "/guides/" },
      { name: title },
    ];
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    item: new URL(item.href ?? Astro.url.pathname, siteUrl).toString(),
  })),
};
const articleSchema = {
  "@type": "Article",
  "@id": `${canonicalUrl}#article`,
  mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
  headline: title,
  description,
  image: new URL(resolvedSocialImage, siteUrl).toString(),
  articleSection: category,
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
  author: { "@id": organizationId },
  publisher: { "@id": organizationId },
};
const faqSchema = faqs.length > 0 ? {
  "@type": "FAQPage",
  "@id": `${canonicalUrl}#faq`,
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
} : undefined;
const machineReadableDate = date.startsWith("Published")
  ? datePublished
  : dateModified ?? datePublished;
---

<BaseLayout
  title={title}
  seoTitle={seoTitle}
  description={description}
  image={resolvedSocialImage}
  imageAlt={resolvedSocialImageAlt}
  ogType="article"
  structuredData={[breadcrumbSchema, articleSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <header class:list={["article-header", image && "image-header"]}>
    {image && (
      <img
        class="header-image"
        src={image}
        alt={imageAlt}
        width="1600"
        height="720"
        loading="eager"
        draggable="false"
        style={`object-position: ${imagePosition};`}
      />
    )}
    <div class="narrow">
      <Breadcrumbs items={breadcrumbItems} />
      <p class="eyebrow">{category}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <p class="article-meta">
        By <a class="article-author" href="/about/">Australian Home Collective</a>
        <span aria-hidden="true"> · </span>
        {machineReadableDate ? <time datetime={machineReadableDate}>{date}</time> : date}
        <span aria-hidden="true"> · </span>{readingTime}
      </p>
      {shouldShowDisclosure && <AffiliateDisclosureBlock compact />}
    </div>
  </header>
  <article class="content narrow">
    <slot />
    {faqs.length > 0 && <FAQBlock items={faqs} />}
  </article>
</BaseLayout>
