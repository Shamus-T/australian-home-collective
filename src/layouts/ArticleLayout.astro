---
import BaseLayout from "./BaseLayout.astro";
import AffiliateDisclosureBlock from "../components/AffiliateDisclosureBlock.astro";
import { getCategorySocialImage } from "../data/socialImages";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  category: string;
  date: string;
  readingTime: string;
  showAffiliateDisclosure?: boolean;
  showDisclosure?: boolean;
  image?: string;
  imageAlt?: string;
  socialImage?: string;
  socialImageAlt?: string;
  imagePosition?: string;
}

const {
  title,
  seoTitle,
  description,
  category,
  date,
  readingTime,
  showAffiliateDisclosure,
  showDisclosure,
  image,
  imageAlt = "",
  socialImage,
  socialImageAlt,
  imagePosition = "center",
} = Astro.props;

const shouldShowDisclosure = showAffiliateDisclosure ?? showDisclosure ?? false;
const categorySocialImage = getCategorySocialImage(category);
const resolvedSocialImage = socialImage ?? categorySocialImage.src;
const resolvedSocialImageAlt = socialImageAlt
  ?? (socialImage ? `${title} - Australian Home Collective` : categorySocialImage.alt);
---

<BaseLayout title={title} seoTitle={seoTitle} description={description} image={resolvedSocialImage} imageAlt={resolvedSocialImageAlt} ogType="article">
  <header class:list={["article-header", image && "image-header"]}>
    {image && (
      <img
        class="header-image"
        src={image}
        alt={imageAlt}
        width="1600"
        height="720"
        loading="eager"
        draggable="false"
        style={`object-position: ${imagePosition};`}
      />
    )}
    <div class="narrow">
      <p class="eyebrow">{category}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <p class="article-meta">{date} - {readingTime}</p>
      {shouldShowDisclosure && <AffiliateDisclosureBlock compact />}
    </div>
  </header>
  <article class="content narrow">
    <slot />
  </article>
</BaseLayout>
