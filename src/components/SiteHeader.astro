---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/categories/", label: "Categories" },
  { href: "/guides/", label: "Guides" },
  { href: "/how-we-select-products/", label: "How We Select" },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand brand-logo" href="/" aria-label="Australian Home Collective home">
      <picture>
        <source srcset="/images/header-title.webp?v=1" type="image/webp" />
        <img
          src="/images/header-title.png?v=6"
          alt="Australian Home Collective"
          width="1200"
          height="300"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          draggable="false"
        />
      </picture>
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
