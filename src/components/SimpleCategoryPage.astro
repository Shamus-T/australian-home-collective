---
import CategoryHubLayout from "../layouts/CategoryHubLayout.astro";
import GuideCard from "./GuideCard.astro";
import ProductCard from "./ProductCard.astro";
import FAQBlock from "./FAQBlock.astro";

interface LinkItem {
  href: string;
  title: string;
  seoTitle?: string;
  description: string;
}

interface ProductType {
  label: string;
  title: string;
  description: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  intro: string;
  focusIntro: string;
  guides?: LinkItem[];
  guideHeading?: string;
  guideIntro?: string;
  secondaryGuides?: LinkItem[];
  secondaryGuideHeading?: string;
  secondaryGuideIntro?: string;
  compare: string[];
  mistakes: string[];
  productTypes: ProductType[];
  faqs: FAQ[];
  relatedCategories?: LinkItem[];
}

const {
  title,
  seoTitle,
  description,
  intro,
  focusIntro,
  guides = [],
  guideHeading = "Useful guides",
  guideIntro = "Choose the guide that matches the part of the room or routine you are working on.",
  secondaryGuides = [],
  secondaryGuideHeading = "More guides",
  secondaryGuideIntro = "These guides cover nearby household routines that may be part of the same job.",
  compare,
  mistakes,
  productTypes,
  faqs,
  relatedCategories = [],
} = Astro.props;
const categoryImages: Record<string, { image: string; alt: string }> = {
  "Nursery & Kids": {
    image: "/images/Nursery-kids.webp",
    alt: "A tidy nursery room with timber furniture, soft lighting and practical baby storage",
  },
  Kitchen: {
    image: "/images/kitchen.webp",
    alt: "A warm kitchen with timber cabinetry, green accents and a tidy benchtop",
  },
  Pets: {
    image: "/images/guides/pet-essentials-home-zones.webp",
    alt: "A dog resting in a practical pet zone with bedding, a lead, grooming supplies and clear household access",
  },
  Laundry: {
    image: "/images/laundry.webp",
    alt: "A practical laundry room with warm finishes and tidy storage",
  },
  Bathroom: {
    image: "/images/bathroom.webp",
    alt: "A warm bathroom with natural finishes and tidy everyday storage",
  },
  Bedroom: {
    image: "/images/bedroom.webp",
    alt: "A calm bedroom with soft bedding and warm natural light",
  },
  "Living Spaces": {
    image: "/images/living-room.webp",
    alt: "A warm living room with timber shelving, soft furnishings and natural light",
  },
  "Garage & Storage": {
    image: "/images/garage.webp",
    alt: "An organised garage with wall storage, cabinets and clear floor space",
  },
  "Garage Storage": {
    image: "/images/garage.webp",
    alt: "An organised garage with wall storage, cabinets and clear floor space",
  },
  "Garage Storage Ideas": {
    image: "/images/garage.webp",
    alt: "An organised garage with wall storage, cabinets and clear floor space",
  },
  "Home Office": {
    image: "/images/home-office.webp",
    alt: "A warm home office with a timber desk, greenery and soft natural light",
  },
  "Outdoor & Garden": {
    image: "/images/outdoor-garden.webp",
    alt: "A warm Australian patio garden with timber seating, native greenery and soft afternoon light",
  },
};
const selectedImage = categoryImages[title] ?? categoryImages["Living Spaces"];
---

<CategoryHubLayout title={title} seoTitle={seoTitle} description={description} intro={intro} image={selectedImage.image} imageAlt={selectedImage.alt}>
  {guides.length > 0 && (
    <section class="section">
      <div class="container section-heading">
        <div>
          <p class="eyebrow">Start here</p>
          <h2>{guideHeading}</h2>
        </div>
        <p>{guideIntro}</p>
      </div>
      <div class="container grid three">
        {guides.map((guide) => (
          <GuideCard href={guide.href} title={guide.title} description={guide.description} meta="Guide" />
        ))}
      </div>
    </section>
  )}

  {secondaryGuides.length > 0 && (
    <section class="section soft">
      <div class="container section-heading">
        <div>
          <p class="eyebrow">Also useful</p>
          <h2>{secondaryGuideHeading}</h2>
        </div>
        <p>{secondaryGuideIntro}</p>
      </div>
      <div class="container grid three">
        {secondaryGuides.map((guide) => (
          <GuideCard href={guide.href} title={guide.title} description={guide.description} meta="Guide" />
        ))}
      </div>
    </section>
  )}

  <section class:list={["section", (guides.length > 0 || secondaryGuides.length > 0) && "soft"]}>
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Category focus</p>
        <h2>What matters in this part of the home</h2>
      </div>
      <p>{focusIntro}</p>
    </div>
    <div class="container grid three">
      {productTypes.map((item) => (
        <ProductCard label={item.label} title={item.title} description={item.description} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Plan first</p>
        <h2>Questions worth asking</h2>
        <ul class="feature-list">
          {compare.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div>
        <p class="eyebrow">Common mistakes</p>
        <h2>Where plans often come unstuck</h2>
        <ul class="feature-list">
          {mistakes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  {relatedCategories.length > 0 && (
    <section class="section soft">
      <div class="container section-heading">
        <div>
          <p class="eyebrow">Related areas</p>
          <h2>Explore nearby categories</h2>
        </div>
        <p>
          Rooms rarely work in isolation. These nearby categories may help with another
          part of the same job.
        </p>
      </div>
      <div class="container grid two">
        {relatedCategories.map((category) => (
          <GuideCard
            href={category.href}
            title={category.title}
            description={category.description}
            meta="Category"
          />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="narrow">
      <FAQBlock items={faqs} />
    </div>
  </section>
</CategoryHubLayout>
